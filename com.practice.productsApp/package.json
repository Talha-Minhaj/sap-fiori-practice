{
    "name": "com.practice.productsapp",
    "scripts": {
        "build": "mbt build --mtar com.practice.productsApp.mtar",
        "build:workspaces": "npm run build --workspaces --if-present",
        "deploy": "cf deploy mta_archives/com.practice.productsApp.mtar --retries 0",
        "lint": "npm run lint --workspaces --if-present",
        "ui5lint": "npm run ui5lint --workspaces --if-present",
        "start:products": "npm start --workspace products"
    },
    "dependencies": {
        "mbt": "^1"
    },
    "workspaces": [
        "products"
    ]
}