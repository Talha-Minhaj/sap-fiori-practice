{
    "name": "products",
    "version": "0.0.1",
    "private": true,
    "description": "products description",
    "keywords": [
        "ui5",
        "openui5",
        "sapui5"
    ],
    "main": "webapp/index.html",
    "devDependencies": {
        "@sap-ux/eslint-plugin-fiori-tools": "^0.2",
        "@sap-ux/preview-middleware": "^0.25.41",
        "@sap/ux-ui5-tooling": "1",
        "@ui5/cli": "^4.0.52",
        "@ui5/linter": "latest",
        "@wdio/cli": "^9.27.1",
        "@wdio/local-runner": "^9.27.1",
        "@wdio/mocha-framework": "^9.27.1",
        "@wdio/spec-reporter": "^9.27.1",
        "json-server": "^0.17.4",
        "wdio-ui5-service": "^3.0.8"
    },
    "scripts": {
        "start": "fiori run --open index.html",
        "start:mock": "json-server --watch db.json --port 3001",
        "build": "ui5 build --config=ui5.yaml --clean-dest --dest ../dist/products",
        "ui5lint": "ui5lint",
        "lint": "eslint ./",
        "qunit": "fiori run --open test/unitTests.qunit.html",
        "opa5": "fiori run --open test/opaTests.qunit.html",
        "wdi5": "wdio run ./webapp/test/e2e/\\wdio.conf.js"
    }
}
